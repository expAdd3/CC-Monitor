{
  "_comment": "自定义模型价格,会覆盖/补充内置表。把本文件复制为 ~/.cc-monitor/prices.json 后修改。",
  "_format": "模型名关键字(小写,子串匹配): [输入, 缓存写入, 缓存读取, 输出],单位 美元/百万token",
  "_example_array": "glm-4.6: [0.6, 0.6, 0.11, 2.2]",
  "_example_object": "也支持对象写法,见下方 my-custom-model",

  "glm-4.6": [0.60, 0.60, 0.11, 2.20],
  "deepseek": [0.27, 0.27, 0.07, 1.10],

  "my-custom-model": {
    "input": 1.0,
    "cache_write": 1.25,
    "cache_read": 0.1,
    "output": 5.0
  }
}
